{
  "manifest_version": 3,
  "name": "GitHub Radius",
  "description": "Adds Radius Deploy button to GitHub repositories for defining and deploying applications",
  "version": "0.1.0",
  "content_scripts": [
    {
      "matches": ["https://github.com/*/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/radius-16.png",
    "48": "icons/radius-48.png",
    "128": "icons/radius-128.png"
  }
}